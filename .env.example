# Copy this file to `.env` and fill in your Spotify credentials:
#   cp .env.example .env
#
# Variable names and defaults follow the upstream Spooty README:
# https://github.com/Raiper34/spooty#environment-variables
#
# Local Docker Compose (see docker-compose.yml: `build: .`, `image: spooty:local`):
#   docker compose up --build
# Example volume binds in docker-compose.yml — adjust paths for your machine:
#   /path/to/downloads -> /spooty/backend/downloads
#   /path/to/cookies.txt -> /spooty/config/cookies.txt (read-only)
#
# Required for Docker:
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
# Loopback IP only — Spotify does not allow localhost redirect URIs.
# Register in Dashboard: http://127.0.0.1:3000/api/auth/spotify/callback
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/spotify/callback
SPOTIFY_AUTH_SCOPES=playlist-read-private playlist-read-collaborative

# Paths (defaults are relative to the backend; Docker image layout may differ)
DB_PATH=./config/db.sqlite
FE_PATH=../frontend/browser
DOWNLOADS_PATH=./downloads

# Audio
FORMAT=mp3
# QUALITY=

# Server
PORT=3000

# Redis (docker-compose overrides REDIS_HOST to `redis` for the app container)
REDIS_PORT=6379
REDIS_HOST=localhost
REDIS_RUN=true

# YouTube (docker-compose sets YT_COOKIES_FILE to the mounted path; leave YT_COOKIES empty in Docker)
YT_COOKIES=
YT_COOKIES_FILE=/spooty/config/cookies.txt
YT_DOWNLOADS_PER_MINUTE=5
